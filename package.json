{
  "name": "reversa",
  "version": "1.2.44",
  "description": "AI evidence, contradiction, and guarded patch-intelligence engine for codebases, devices, runtimes, games, and agent workflows",
  "bin": {
    "reversa": "bin/reversa.js"
  },
  "type": "module",
