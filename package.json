  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fractal-Echo/Reversa-Matrix.git"
  },
  "homepage": "https://github.com/Fractal-Echo/Reversa-Matrix",
  "bugs": {
    "url": "https://github.com/Fractal-Echo/Reversa-Matrix/issues"
  },
  "engines": {
