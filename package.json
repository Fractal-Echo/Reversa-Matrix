    "ai",
    "codex",
    "claude",
    "agents"
  ],
  "files": [
    "agents/",
    "bin/",
    "docs/",
    "lib/",
    "profiles/",
    "reversa-studio/",
    "reversa-runtime/",
    "scripts/",
    "templates/",
    "README.md",
    "LICENSE"
